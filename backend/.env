# OpenAgriNet local PostgreSQL (Docker on port 5433)
DATABASE_URL=postgresql://admin:admin@localhost:5433/openagrinet

# JWT for /api/* (same secret for HS256 tokens issued after login)
JWT_SECRET=dev-secret

# Keycloak — start with: docker compose -f infrastructure/docker-compose.yml up -d keycloak
# Host URL (local Node backend). Inside Docker backend use: http://keycloak:8080
KEYCLOAK_ENABLED=true
KEYCLOAK_URL=http://$EC2_HOST/auth
KEYCLOAK_CLIENT_ID=openagrinet-web
